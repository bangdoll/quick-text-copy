{
  "manifest_version": 3,
  "name": "Quick Text Copy (Professional)",
  "version": "1.2.0",
  "description": "專業版：整合 OpenCC 引擎，支援本地精準簡繁轉換。一鍵複製網頁標題與網址。",
  "author": "Quick Text Copy Team",
  "permissions": [
    "activeTab",
    "scripting",
    "notifications",
    "clipboardWrite"
  ],
  "action": {
    "default_title": "快速複製 (OpenCC 轉換)"
  },
  "background": {
    "service_worker": "src/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "88",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}