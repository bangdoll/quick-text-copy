{
  "manifest_version": 3,
  "name": "Quick Text Copy",
  "version": "1.0.4",
  "description": "快速複製當前頁面的標題和網址到剪貼簿，格式：標題 網址",
  "author": "Chrome Extension Developer",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "permissions_description": "此擴充功能需要 activeTab 權限來讀取當前分頁的標題和網址，以及 scripting 權限來執行複製到剪貼簿的功能。我們不會收集或儲存任何個人資料。",
  "action": {
    "default_title": "複製頁面資訊",
    "default_popup": ""
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "88",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}