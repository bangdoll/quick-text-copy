{
  "name": "quick-text-copy",
  "version": "1.2.1",
  "description": "A powerful Chrome extension with quick text copy and OpenCC Simplified to Traditional Chinese conversion features",
  "main": "service-worker.js",
  "homepage": "https://github.com/bangdoll/quick-text-copy",
  "repository": {
    "type": "git",
    "url": "https://github.com/bangdoll/quick-text-copy.git"
  },
  "bugs": {
    "url": "https://github.com/bangdoll/quick-text-copy/issues"
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "build:watch": "webpack --mode development --watch",
    "build:package": "node scripts/package.js",
    "build:clean": "node build-clean-extension.js",
    "build:legacy": "node build-package.js",
    "test": "node run-tests.js all",
    "test:unit": "node run-tests.js unit",
    "test:integration": "node run-tests.js integration",
    "test:e2e": "node run-tests.js e2e",
    "test:compliance": "node run-tests.js compliance",
    "test:coverage": "node run-tests.js coverage",
    "test:watch": "node run-tests.js watch",
    "test:quick": "node run-tests.js quick",
    "test:jest": "jest",
    "test:jest-unit": "jest --testPathPattern=tests/unit",
    "test:jest-integration": "jest --testPathPattern=tests/integration",
    "test:jest-coverage": "jest --coverage",
    "test:jest-watch": "jest --watch",
    "test:legacy": "node test-extension.js",
    "compliance-check": "node run-compliance-check.js",
    "check-permissions": "node -e \"const ComplianceChecker = require('./compliance-checker'); const checker = new ComplianceChecker(); checker.checkPermissions();\"",
    "check-privacy": "node -e \"const ComplianceChecker = require('./compliance-checker'); const checker = new ComplianceChecker(); checker.checkPrivacyPolicy();\"",
    "check-security": "node -e \"const ComplianceChecker = require('./compliance-checker'); const checker = new ComplianceChecker(); checker.checkContentSecurityPolicy();\"",
    "check-functionality": "node -e \"const ComplianceChecker = require('./compliance-checker'); const checker = new ComplianceChecker(); checker.checkFunctionality();\"",
    "setup-account": "node setup-developer-account.js",
    "check-account": "node check-developer-account.js",
    "review-status": "node review-status-cli.js",
    "monitor-start": "node auto-review-monitor.js start",
    "monitor-stop": "node auto-review-monitor.js stop",
    "monitor-status": "node auto-review-monitor.js status",
    "submission-check": "node chrome-store-submission.js check",
    "submission-prepare": "node chrome-store-submission.js prepare",
    "submission-submit": "node chrome-store-submission.js submit",
    "post-launch-monitor": "node post-launch-monitor.js",
    "version-create": "node version-update-manager.js create",
    "version-prepare": "node version-update-manager.js prepare",
    "version-submit": "node version-update-manager.js submit",
    "version-status": "node version-update-manager.js status",
    "version-history": "node version-update-manager.js history",
    "support-create": "node user-support-system.js create",
    "support-list": "node user-support-system.js list",
    "support-report": "node user-support-system.js report",
    "performance-collect": "node performance-error-monitor.js collect",
    "performance-report": "node performance-error-monitor.js report",
    "performance-start": "node performance-error-monitor.js start",
    "performance-stop": "node performance-error-monitor.js stop",
    "emergency-rollback": "node emergency-rollback.js execute",
    "emergency-rollback-prepare": "node emergency-rollback.js prepare",
    "emergency-rollback-verify": "node emergency-rollback.js verify",
    "handle-rejection": "node handle-review-rejection.js handle",
    "quick-fix": "node handle-review-rejection.js quick-fix",
    "validate-manifest": "node -e \"const fs = require('fs'); try { JSON.parse(fs.readFileSync('./manifest.json', 'utf8')); console.log('manifest.json 格式正確'); } catch(e) { console.error('manifest.json 格式錯誤:', e.message); process.exit(1); }\"",
    "validate-permissions": "node -e \"const ComplianceChecker = require('./compliance-checker'); const checker = new ComplianceChecker(); checker.checkPermissions();\"",
    "validate-store-listing": "node -e \"const fs = require('fs'); const config = JSON.parse(fs.readFileSync('./chrome-store-listing/store-listing-config.json', 'utf8')); console.log('商店列表配置驗證通過');\"",
    "quick-test": "node test-extension.js --quick",
    "test-extension": "node test-extension.js",
    "test-all-features": "node test-extension.js --comprehensive",
    "test-chinese-conversion": "node test-simple-conversion.js",
    "test-number-filter": "node test-number-prefix-filter.js",
    "test-complete": "node test-complete-functionality.js",
    "demo-chinese-conversion": "node demo-chinese-conversion.js",
    "demo-number-filter": "node demo-number-filter.js",
    "update-prepare": "node chrome-store-update.js prepare",
    "update-check": "node chrome-store-update.js check",
    "update-version": "node chrome-store-update.js version",
    "update-existing": "node update-existing-extension.js update",
    "check-status": "node check-store-status.js status",
    "check-upload": "node check-store-status.js check-update",
    "generate-screenshots": "node generate-demo-screenshots.js",
    "convert-screenshots": "node convert-svg-to-png.js",
    "validate-screenshots": "node -e \"const fs = require('fs'); const path = './chrome-store-listing/screenshots/'; if (fs.existsSync(path)) { const files = fs.readdirSync(path).filter(f => f.endsWith('.png')); console.log('找到', files.length, '個截圖檔案'); } else { console.error('截圖目錄不存在'); }\"",
    "analyze-package-size": "node -e \"const fs = require('fs'); const stats = fs.statSync('./quick-text-copy-extension.zip'); console.log('套件大小:', Math.round(stats.size / 1024), 'KB');\"",
    "optimize-resources": "node -e \"console.log('資源最佳化功能開發中...');\"",
    "fix-manifest-issues": "node -e \"console.log('manifest 自動修正功能開發中...');\"",
    "pre-submission-check": "npm run validate-manifest && npm run compliance-check && npm run test-extension",
    "generate-fix-report": "node -e \"console.log('修正報告生成功能開發中...');\"",
    "resubmit": "npm run build && echo '準備重新提交...'",
    "diagnose-errors": "node -e \"console.log('錯誤診斷功能開發中...');\"",
    "verify-icons": "node verify-icons.js",
    "final-check": "npm run pre-submission-check && echo '最終檢查完成'",
    "emergency-drill": "node emergency-drill.js monthly",
    "emergency-drill-quarterly": "node emergency-drill.js quarterly",
    "emergency-drill-full": "node emergency-drill.js full",
    "test-opencc": "node test-opencc-converter.js",
    "demo-opencc": "node demo-opencc-usage.js",
    "demo-opencc-integration": "node opencc-integration-example.js",
    "verify-opencc": "node verify-opencc-fix.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "convert:zh": "node scripts/convert-zh.js",
    "release": "node scripts/release.js",
    "release:prepare": "node scripts/release.js --prepare",
    "release:publish": "node scripts/release.js --publish",
    "prepare": "husky install",
    "postinstall": "husky install"
  },
  "keywords": [
    "chrome-extension",
    "text-copy",
    "opencc",
    "chinese-conversion",
    "simplified-traditional",
    "browser-extension",
    "productivity",
    "wasm"
  ],
  "author": "Quick Text Copy Team",
  "license": "MIT",
  "dependencies": {
    "canvas": "^3.1.2",
    "opencc-js": "^1.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.8",
    "archiver": "^6.0.1",
    "commander": "^11.1.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jest": "^27.6.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.1.0",
    "prettier": "^3.1.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "lint-staged": {
    "*.{js,json,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run test:unit"
    }
  }
}
